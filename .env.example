################################################################################
# .env.example — environment variable template for the ASR stack
#
# Copy this file to .env and adjust values for your environment:
#   cp .env.example .env
#
# .env is intentionally listed in .gitignore — never commit real secrets.
################################################################################

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_USER=asr
POSTGRES_PASSWORD=asr_secret_change_me
POSTGRES_DB=asr
# Port exposed to the host (change if 5432 is already in use)
POSTGRES_PORT=5432

# ---------------------------------------------------------------------------
# ASR service
# ---------------------------------------------------------------------------
# Port the FastAPI service listens on (host side)
ASR_PORT=8000

# Whisper model to load. Options: tiny, base, small, medium, large-v2, large-v3
WHISPER_MODEL=large-v3

# Inference device: "cuda" (GPU) or "cpu" (no GPU)
WHISPER_DEVICE=cuda

# CTranslate2 quantisation type.
#   GPU:  float16 | float32 | int8_float16
#   CPU:  int8    | float32
WHISPER_COMPUTE_TYPE=float16
